@inject NavigationManager Navigation
@using ShopWaveBlazor.Web.ECommerceAPI.Models

<div class="glass-card product-card animate-fade-in">
    <div class="product-image-container" @onclick="NavigateToDetails">
        <img src="@Product.ImageURL" alt="@Product.ProductName" />
        <div class="product-overlay">
            <button class="btn-view-details">Quick View</button>
        </div>
        @if (Product.StockQuantity <= 5 && Product.StockQuantity > 0)
        {
            <div class="stock-badge warning">Only @Product.StockQuantity left!</div>
        }
        else if (Product.StockQuantity == 0)
        {
            <div class="stock-badge danger">Out of Stock</div>
        }
    </div>

    <div class="product-info p-3">
        <div class="d-flex justify-content-between align-items-start mb-2">
            <div>
                <h5 class="product-title mb-1">@Product.ProductName</h5>
                <span class="product-category">Electronics</span>
            </div>
            <div class="product-price">Rs. @Product.Price.ToString("N0")</div>
        </div>
        
        <p class="product-desc small mb-3">@Product.Description</p>

        <div class="product-actions d-flex gap-2">
            <button class="btn btn-premium flex-grow-1" @onclick="OnAddToCart" disabled="@(Product.StockQuantity <= 0)">
                <i class="bi bi-cart-plus"></i> Add to Cart
            </button>
            <button class="btn glass-card p-2" @onclick="OnToggleWishlist">
                <i class="bi bi-heart"></i>
            </button>
        </div>
    </div>
</div>

<style>
    .product-card {
        overflow: hidden;
        display: flex;
        flex-direction: column;
        height: 100%;
        padding: 0 !important;
    }

    .product-image-container {
        position: relative;
        height: 220px;
        overflow: hidden;
        cursor: pointer;
    }

    .product-image-container img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .product-card:hover .product-image-container img {
        transform: scale(1.1);
    }

    .product-overlay {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.4);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    .product-card:hover .product-overlay {
        opacity: 1;
    }

    .btn-view-details {
        background: white;
        color: black;
        border: none;
        padding: 8px 16px;
        border-radius: 20px;
        font-weight: 600;
        font-size: 0.8rem;
        transform: translateY(20px);
        transition: all 0.3s ease;
    }

    .product-card:hover .btn-view-details {
        transform: translateY(0);
    }

    .stock-badge {
        position: absolute;
        top: 10px;
        right: 10px;
        padding: 4px 10px;
        border-radius: 8px;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        backdrop-filter: blur(4px);
    }

    .stock-badge.warning { background: rgba(245, 158, 11, 0.8); color: white; }
    .stock-badge.danger { background: rgba(239, 68, 68, 0.8); color: white; }

    .product-title {
        font-weight: 700;
        color: var(--text-main);
        font-size: 1.1rem;
    }

    .product-category {
        font-size: 0.75rem;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .product-price {
        font-weight: 800;
        color: var(--primary);
        font-size: 1.1rem;
    }

    .product-desc {
        color: var(--text-muted);
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .product-actions .btn {
        border-radius: var(--radius-md);
    }
</style>

@code {
    [Parameter] public Product Product { get; set; } = new();
    [Parameter] public EventCallback<Product> OnAddToCartClick { get; set; }

    private void NavigateToDetails() => Navigation.NavigateTo($"/product/{Product.ProductID}");

    private async Task OnAddToCart()
    {
        await OnAddToCartClick.InvokeAsync(Product);
    }

    private void OnToggleWishlist()
    {
        // Wishlist logic
    }
}
