@page "/product/{id:int}"
@using Microsoft.EntityFrameworkCore
@using ShopWaveBlazor.Web.ECommerceAPI.Models
@using ShopWaveBlazor.Web.Services
@inject IDbContextFactory<ShopWaveBlazor.Web.ECommerceAPI.Data.ECommerceDbContext> DbFactory
@inject NavigationManager Navigation
@inject ShopWaveBlazor.Web.Services.CartService CartService
@inject ShopWaveBlazor.Web.Services.AuthService AuthService
@inject ShopWaveBlazor.Web.Services.ReviewService ReviewService

<PageTitle>@(product != null ? $"{product.ProductName} — ShopWave" : "Product Details")</PageTitle>

<div class="pd-wrapper">
    @if (product == null)
    {
        <!-- SKELETON -->
        <div class="pd-skeleton">
            <div class="pd-skel-img skeleton"></div>
            <div class="pd-skel-info">
                <div class="skeleton-text w-40" style="height:14px;margin-bottom:16px;"></div>
                <div class="skeleton-text"      style="height:32px;margin-bottom:10px;"></div>
                <div class="skeleton-text w-60" style="height:32px;margin-bottom:24px;"></div>
                <div class="skeleton-text"      style="height:14px;margin-bottom:8px;"></div>
                <div class="skeleton-text w-60" style="height:14px;margin-bottom:8px;"></div>
                <div class="skeleton-text w-40" style="height:14px;margin-bottom:32px;"></div>
                <div class="skeleton-text"      style="height:52px;border-radius:12px;"></div>
            </div>
        </div>
    }
    else
    {
        <!-- BREADCRUMB -->
        <div class="pd-breadcrumb">
            <a href="/">Home</a>
            <i class="bi bi-chevron-right"></i>
            <span>@(product.Category?.CategoryName ?? "General")</span>
            <i class="bi bi-chevron-right"></i>
            <span class="active">@product.ProductName</span>
        </div>

        <!-- PRODUCT DETAIL LAYOUT -->
        <div class="product-detail-layout">

            <!-- LEFT: GALLERY -->
            <div class="product-gallery">
                <div class="main-img-wrap">
                    <img src="@ProductImageService.GetImage(product.ProductName, product.Category?.CategoryName)"
                         class="main-img"
                         alt="@product.ProductName"
                         onerror="this.src='https://images.unsplash.com/photo-1560472355-536de3962603?w=600&q=80'" />

                    @if (product.StockQuantity == 0)
                    {
                        <div class="gallery-badge sold-out">Sold Out</div>
                    }
                    else if (product.StockQuantity <= 5)
                    {
                        <div class="gallery-badge low-stock">Only @product.StockQuantity left!</div>
                    }

                    <button class="gallery-wish @(isWishlisted ? "active" : "")" aria-label="Toggle wishlist" @onclick="() => isWishlisted = !isWishlisted">
                        <i class="bi @(isWishlisted ? "bi-heart-fill" : "bi-heart")"></i>
                    </button>
                </div>

                <!-- THUMBNAILS -->
                <div class="thumb-row">
                    @for (int i = 0; i < 4; i++)
                    {
                        var idx = i;
                        <div class="thumb @(activeThumb == idx ? "active" : "")"
                             @onclick="() => activeThumb = idx">
                            <img src="@ProductImageService.GetImage(product.ProductName, product.Category?.CategoryName)"
                                 style="@(idx > 0 ? "filter:brightness(0.5)" : "")"
                                 alt="Thumbnail @idx" />
                        </div>
                    }
                </div>

                <!-- DELIVERY INFO BOX -->
                <div class="delivery-box">
                    <div class="delivery-row">
                        <i class="bi bi-truck text-primary"></i>
                        <div>
                            <strong>Free Delivery</strong>
                            <span>Estimated 5-7 business days</span>
                        </div>
                    </div>
                    <div class="delivery-row">
                        <i class="bi bi-arrow-repeat text-success"></i>
                        <div>
                            <strong>7-Day Returns</strong>
                            <span>Hassle-free return policy</span>
                        </div>
                    </div>
                    <div class="delivery-row">
                        <i class="bi bi-shield-check text-gold"></i>
                        <div>
                            <strong>Buyer Protection</strong>
                            <span>100% secure checkout</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- RIGHT: INFO -->
            <div class="product-detail-info">

                <!-- CATEGORY + BADGES -->
                <div class="pd-top-row">
                    <span class="category-tag">@(product.Category?.CategoryName ?? "General")</span>
                    <span class="badge badge-success">Verified Seller</span>
                </div>

                <!-- TITLE -->
                <h1 class="product-title">@product.ProductName</h1>

                <!-- RATING -->
                <div class="rating-big">
                    <div class="stars-big">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <span class="@(i <= Math.Round(product.Rating) ? "text-gold" : "text-muted")">★</span>
                        }
                    </div>
                    <span class="rating-num">@product.Rating.ToString("F1")</span>
                    <span class="review-count">(@product.TotalReviews reviews)</span>
                    <span class="sold-count">· 340 sold</span>
                </div>

                <!-- PRICE -->
                <div class="price-big-wrap">
                    <div class="price-big">Rs. @product.Price.ToString("N0")</div>
                    <div class="price-big-meta">
                        <span class="price-old">Rs. @((product.Price * 1.2m).ToString("N0"))</span>
                        <span class="badge badge-success">20% OFF</span>
                    </div>
                    <div class="savings-note">
                        <i class="bi bi-piggy-bank"></i>
                        You save Rs. @((product.Price * 0.2m).ToString("N0")) on this order!
                    </div>
                </div>

                <div class="pd-divider"></div>

                <!-- DESCRIPTION -->
                <p class="pd-desc">@product.Description</p>

                <!-- STOCK STATUS -->
                <div class="stock-row">
                    @if (product.StockQuantity > 5)
                    {
                        <span class="stock-dot green"></span>
                        <span class="stock-label">In Stock</span>
                        <span class="stock-count">(@product.StockQuantity units available)</span>
                    }
                    else if (product.StockQuantity > 0)
                    {
                        <span class="stock-dot yellow"></span>
                        <span class="stock-label warn">Low Stock!</span>
                        <span class="stock-count">Only @product.StockQuantity left — order soon</span>
                    }
                    else
                    {
                        <span class="stock-dot red"></span>
                        <span class="stock-label danger">Out of Stock</span>
                    }
                </div>

                <!-- QUANTITY -->
                <div class="qty-row">
                    <span class="qty-label">Quantity:</span>
                    <div class="qty-control">
                        <button class="qty-btn" @onclick="Dec" disabled="@(qty <= 1)" aria-label="Decrease quantity">−</button>
                        <span class="qty-display">@qty</span>
                        <button class="qty-btn" @onclick="Inc" disabled="@(qty >= product.StockQuantity)" aria-label="Increase quantity">+</button>
                    </div>
                    <span class="qty-hint">Max @product.StockQuantity units</span>
                </div>

                <!-- ACTION BUTTONS -->
                <div class="pd-actions">
                    <button class="btn-lg btn-add"
                            disabled="@(product.StockQuantity == 0)"
                            @onclick="AddToCart">
                        <i class="bi bi-cart-plus"></i>
                        @(product.StockQuantity == 0 ? "Out of Stock" : "Add to Cart")
                    </button>
                    <button class="btn-lg btn-buy"
                            disabled="@(product.StockQuantity == 0 || isLoadingAction)"
                            @onclick="BuyNow">
                        <i class="bi bi-lightning-fill"></i> Buy Now
                    </button>
                </div>

                @if (cartSuccess)
                {
                    <div class="cart-toast">
                        <i class="bi bi-check-circle-fill"></i> Added to cart successfully!
                    </div>
                }

                <div class="pd-divider"></div>

                <!-- SPECS TABLE -->
                <div class="specs-section">
                    <h4 class="specs-title">
                        <i class="bi bi-list-ul"></i> Product Specifications
                    </h4>
                    <table class="spec-table">
                        <tr><td>Brand</td><td>ShopWave Premium</td></tr>
                        <tr><td>Category</td><td>@(product.Category?.CategoryName ?? "General")</td></tr>
                        <tr><td>Stock</td><td>@product.StockQuantity units</td></tr>
                        <tr><td>Warranty</td><td>1 Year Official Warranty</td></tr>
                    </table>
                </div>
            </div>
        </div>

        <!-- REVIEWS SECTION -->
        <div class="reviews-section">
            <div class="reviews-header">
                <h3><i class="bi bi-chat-square-text"></i> Customer Reviews</h3>
                <div class="reviews-summary">
                    <div class="rating-big-score">@product.Rating.ToString("F1")</div>
                    <div>
                        <div class="stars-big">
                             @for (int i = 1; i <= 5; i++)
                             {
                                <span class="@(i <= Math.Round(product.Rating) ? "text-gold" : "text-muted")">★</span>
                             }
                        </div>
                        <span class="review-count">Based on @product.TotalReviews reviews</span>
                    </div>
                </div>
            </div>

            <div class="review-submission-box card">
                <div class="card-body">
                    <h5>Share your thoughts</h5>
                    <p class="text-muted small">Aapko ye product kaisa laga? Apna feedback dein.</p>
                    
                    @if (!AuthService.IsAuthenticated)
                    {
                        <div class="alert alert-info py-2">Please <a href="/login">login</a> to write a review.</div>
                    }
                    else
                    {
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label">Rating</label>
                                <select class="form-control" @bind="newReviewRating">
                                    <option value="5">⭐⭐⭐⭐⭐ (Excellent)</option>
                                    <option value="4">⭐⭐⭐⭐ (Good)</option>
                                    <option value="3">⭐⭐⭐ (Average)</option>
                                    <option value="2">⭐⭐ (Poor)</option>
                                    <option value="1">⭐ (Very Bad)</option>
                                </select>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Review Comment</label>
                                <textarea class="form-control" rows="3" placeholder="Write your experience..." @bind="newReviewComment"></textarea>
                            </div>
                            <div class="col-12">
                                <button class="btn btn-primary btn-sm" @onclick="SubmitReview" disabled="@isSubmittingReview">
                                    @if (isSubmittingReview) { <span class="spinner-border spinner-border-sm me-2"></span> }
                                    Submit Review
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="reviews-grid">
                @if (!productReviews.Any())
                {
                    <div class="empty-reviews text-center py-5">
                        <i class="bi bi-chat-dots" style="font-size:3rem; color:var(--text-muted);"></i>
                        <p class="mt-3 text-muted">Abhi tak kisi ne review nahi diya. Pehla review aap dein!</p>
                    </div>
                }
                else
                {
                    @foreach (var review in productReviews)
                    {
                        <div class="review-card">
                            <div class="review-top">
                                <div class="reviewer-avatar">@(review.User?.Username?[0] ?? 'U')</div>
                                <div class="reviewer-info">
                                    <strong>@(review.User?.FullName ?? "ShopWave User")</strong>
                                    <span>@review.ReviewDate.ToString("MMMM dd, yyyy")</span>
                                </div>
                                <div class="review-stars">
                                    @for (int s = 0; s < review.Rating; s++) { <span>★</span> }
                                </div>
                            </div>
                            <p class="review-text">@review.ReviewText</p>
                            <div class="review-badge">
                                <i class="bi bi-patch-check-fill"></i> Verified Purchase
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int id { get; set; }
    private ShopWaveBlazor.Web.ECommerceAPI.Models.Product? product;
    private List<Review> productReviews = new();
    
    private int qty = 1;
    private int activeThumb = 0;
    private bool isWishlisted = false;
    private bool cartSuccess = false;
    private bool isLoadingAction = false;
    
    private int newReviewRating = 5;
    private string newReviewComment = "";
    private bool isSubmittingReview = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadProductData();
    }

    private async Task LoadProductData()
    {
        using var Db = await DbFactory.CreateDbContextAsync();
        product = await Db.Products.Include(p => p.Category).FirstOrDefaultAsync(p => p.ProductID == id);
        if (product != null)
        {
            productReviews = await ReviewService.GetProductReviewsAsync(id);
        }
    }

    private void Inc() { if (product != null && qty < product.StockQuantity) qty++; }
    private void Dec() { if (qty > 1) qty--; }

    private async Task AddToCart()
    {
        if (!AuthService.IsAuthenticated) { Navigation.NavigateTo("/login"); return; }
        if (product == null) return;

        isLoadingAction = true;
        await CartService.AddToCartAsync(AuthService.CurrentUser!.UserID, product.ProductID, qty);
        isLoadingAction = false;
        
        cartSuccess = true;
        StateHasChanged();
        await Task.Delay(2500);
        cartSuccess = false;
    }

    private async Task BuyNow()
    {
        if (!AuthService.IsAuthenticated) { Navigation.NavigateTo("/login"); return; }
        if (product == null) return;

        isLoadingAction = true;
        await CartService.AddToCartAsync(AuthService.CurrentUser!.UserID, product.ProductID, qty);
        isLoadingAction = false;
        Navigation.NavigateTo("/checkout");
    }

    private async Task SubmitReview()
    {
        if (string.IsNullOrWhiteSpace(newReviewComment)) return;
        if (product == null || AuthService.CurrentUser == null) return;

        isSubmittingReview = true;
        var review = new Review
        {
            ProductID = product.ProductID,
            UserID = AuthService.CurrentUser.UserID,
            Rating = newReviewRating,
            ReviewText = newReviewComment
        };

        var success = await ReviewService.AddReviewAsync(review);
        if (success)
        {
            newReviewComment = "";
            newReviewRating = 5;
            await LoadProductData(); // Refresh reviews and rating
        }
        isSubmittingReview = false;
    }
}

<style>
    .pd-wrapper { max-width: 1250px; margin: 0 auto; padding: 20px; }

    /* BREADCRUMB */
    .pd-breadcrumb { display: flex; align-items: center; gap: 10px; font-size: 0.85rem; color: #8a8d9e; margin-bottom: 30px; flex-wrap: wrap; text-transform: uppercase; letter-spacing: 1px; }
    .pd-breadcrumb a { color: #8a8d9e; text-decoration: none; transition: color 0.3s; }
    .pd-breadcrumb a:hover { color: var(--primary); }
    .pd-breadcrumb i { font-size: 0.7rem; color: #5c6080; }
    .pd-breadcrumb .active { color: var(--text); font-weight: 600; }

    /* LAYOUT */
    .product-detail-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: start; }

    /* GALLERY */
    .product-gallery { position: sticky; top: 100px; }
    .main-img-wrap { 
        position: relative; border-radius: 20px; overflow: hidden; 
        background: linear-gradient(145deg, #161c2d, #0f1729); 
        border: 1px solid rgba(0,0,0,0.05);
        box-shadow: 0 10px 40px rgba(0,0,0,0.4);
    }
    .main-img { width: 100%; aspect-ratio: 1; object-fit: cover; object-position: center; display: block; }
    
    .gallery-badge { position: absolute; top: 15px; left: 15px; padding: 6px 16px; border-radius: 30px; font-size: 0.8rem; font-weight: 700; color: var(--text); z-index: 10; text-transform: uppercase; letter-spacing: 1px; }
    .gallery-badge.sold-out { background: linear-gradient(135deg, #e63946, #c1121f); }
    .gallery-badge.low-stock { background: linear-gradient(135deg, #f4a261, #e76f51); }

    .gallery-wish { position: absolute; top: 15px; right: 15px; width: 45px; height: 45px; border-radius: 50%; background: rgba(15,23,41,0.6); backdrop-filter: blur(8px); border: 1px solid rgba(0,0,0,0.1); color: var(--text); display: grid; place-items: center; font-size: 1.2rem; cursor: pointer; transition: all 0.3s; z-index: 10; border: none; }
    .gallery-wish:hover { background: rgba(15,23,41,0.9); transform: scale(1.1); }
    .gallery-wish.active i { color: #f06292; }

    .thumb-row { display: flex; gap: 15px; margin-top: 20px; overflow-x: auto; padding-bottom: 10px; }
    .thumb { width: 90px; height: 90px; border-radius: 14px; overflow: hidden; border: 2px solid transparent; cursor: pointer; flex-shrink: 0; transition: all 0.3s; background: var(--surface); }
    .thumb.active { border-color: var(--primary); box-shadow: 0 0 15px rgba(91,141,238,0.3); }
    .thumb img { width: 100%; height: 100%; object-fit: cover; transition: opacity 0.3s; }
    .thumb:not(.active) img { opacity: 0.5; }
    .thumb:hover img { opacity: 1; }

    /* INFO SIDE */
    .pd-top-row { display: flex; align-items: center; gap: 15px; margin-bottom: 15px; }
    .category-tag { font-size: 0.85rem; font-weight: 700; color: var(--primary); text-transform: uppercase; letter-spacing: 1.5px; }
    .badge-success { background: rgba(46,196,182,0.15); border: 1px solid rgba(46,196,182,0.3); color: #2ec4b6; font-size: 0.75rem; padding: 4px 10px; border-radius: 20px; font-weight: 600; }

    .product-title { font-family: 'Syne', sans-serif; font-size: 2.8rem; font-weight: 800; color: var(--text); line-height: 1.1; margin-bottom: 20px; letter-spacing: -1px; }

    .rating-big { display: flex; align-items: center; gap: 12px; margin-bottom: 30px; }
    .stars-big { color: #f4a261; font-size: 1.2rem; letter-spacing: 2px; }
    .rating-num { font-size: 1.1rem; font-weight: 700; color: var(--text); }
    .review-count { font-size: 0.9rem; color: var(--primary); text-decoration: underline; cursor: pointer; }
    .sold-count { font-size: 0.9rem; color: #8a8d9e; }

    /* PRICE */
    .price-big-wrap { margin-bottom: 30px; background: rgba(0,0,0,0.02); padding: 25px; border-radius: 16px; border: 1px solid rgba(0,0,0,0.05); }
    .price-big { font-family: 'Syne', sans-serif; font-size: 3rem; font-weight: 800; color: var(--primary); line-height: 1; margin-bottom: 10px; }
    .price-big-meta { display: flex; align-items: center; gap: 15px; margin-bottom: 10px; }
    .price-old { font-size: 1.2rem; color: #6c7293; text-decoration: line-through; }
    .savings-note { font-size: 0.9rem; color: #2ec4b6; display: flex; align-items: center; gap: 8px; font-weight: 600; }

    .pd-divider { height: 1px; background: rgba(0,0,0,0.05); margin: 30px 0; }

    .pd-desc { font-size: 1.05rem; color: #a0a3bd; line-height: 1.7; margin-bottom: 30px; }

    /* STOCK */
    .stock-row { display: flex; align-items: center; gap: 10px; margin-bottom: 25px; }
    .stock-dot { width: 12px; height: 12px; border-radius: 50%; box-shadow: 0 0 10px currentColor; }
    .stock-dot.green { background: #2ec4b6; color: #2ec4b6; }
    .stock-dot.yellow { background: #f4a261; color: #f4a261; }
    .stock-dot.red { background: #e63946; color: #e63946; }
    .stock-label { font-weight: 600; font-size: 1.1rem; color: var(--text); }
    .stock-count { font-size: 0.9rem; color: #8a8d9e; }

    /* QUANTITY */
    .qty-row { display: flex; align-items: center; gap: 20px; margin-bottom: 40px; }
    .qty-label { font-size: 1.1rem; font-weight: 600; color: var(--text); }
    .qty-control { display: flex; align-items: center; background: rgba(0,0,0,0.05); border: 1px solid rgba(0,0,0,0.1); border-radius: 12px; overflow: hidden; height: 48px; }
    .qty-btn { background: transparent; border: none; color: var(--text); width: 48px; height: 100%; font-size: 1.5rem; cursor: pointer; transition: all 0.2s; display: grid; place-items: center; }
    .qty-btn:hover:not(:disabled) { background: rgba(0,0,0,0.1); }
    .qty-btn:disabled { color: #6c7293; cursor: not-allowed; }
    .qty-display { width: 50px; text-align: center; font-weight: 700; font-size: 1.1rem; color: var(--text); border-left: 1px solid rgba(0,0,0,0.1); border-right: 1px solid rgba(0,0,0,0.1); display: grid; place-items: center; height: 100%; }
    .qty-hint { font-size: 0.9rem; color: #8a8d9e; }

    /* ACTIONS */
    .pd-actions { display: flex; gap: 20px; margin-bottom: 20px; }
    .btn-lg { height: 60px; border-radius: 14px; font-size: 1.1rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; display: flex; justify-content: center; align-items: center; gap: 12px; transition: all 0.3s; border: none; cursor: pointer; flex: 1; }
    .btn-add { background: #111018; color: #FFFFFF; box-shadow: 0 10px 30px rgba(0,0,0,0.1); }
    .btn-add:hover:not(:disabled) { transform: translateY(-3px); box-shadow: 0 15px 40px rgba(0,0,0,0.2); }
    .btn-buy { background: #fff; color: #0f1729; }
    .btn-buy:hover:not(:disabled) { transform: translateY(-3px); background: #f0f0f0; box-shadow: 0 10px 30px rgba(0,0,0,0.2); }
    .btn-lg:disabled { filter: grayscale(1); opacity: 0.5; cursor: not-allowed; box-shadow: none !important; transform: none !important; }

    .cart-toast { background: rgba(46,196,182,0.15); border: 1px solid rgba(46,196,182,0.3); color: #2ec4b6; padding: 15px 20px; border-radius: 12px; display: flex; align-items: center; gap: 10px; font-weight: 600; font-size: 1rem; margin-bottom: 20px; animation: fadeIn 0.3s; }

    /* DELIVERY */
    .delivery-box { margin-top: 30px; background: rgba(0,0,0,0.02); border: 1px solid rgba(0,0,0,0.05); border-radius: 16px; padding: 25px; display: flex; flex-direction: column; gap: 20px; }
    .delivery-row { display: flex; align-items: flex-start; gap: 15px; }
    .delivery-row i { font-size: 1.5rem; }
    .delivery-row strong { display: block; color: var(--text); font-size: 1.05rem; margin-bottom: 4px; }
    .delivery-row span { color: #8a8d9e; font-size: 0.9rem; }
    .text-primary { color: var(--primary) !important; }
    .text-success { color: #2ec4b6 !important; }
    .text-gold { color: #f4a261 !important; }

    /* SPECS */
    .specs-section { margin-top: 40px; }
    .specs-title { font-size: 1.3rem; font-weight: 700; color: var(--text); margin-bottom: 20px; display: flex; align-items: center; gap: 10px; }
    .spec-table { width: 100%; border-collapse: collapse; }
    .spec-table tr { border-bottom: 1px solid rgba(0,0,0,0.05); }
    .spec-table td { padding: 15px 0; color: #a0a3bd; font-size: 1rem; }
    .spec-table td:first-child { font-weight: 600; width: 30%; color: var(--text); }

    /* REVIEWS SECTION */
    .reviews-section { margin-top: 80px; padding-top: 60px; border-top: 1px solid rgba(0,0,0,0.05); }
    .reviews-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 40px; flex-wrap: wrap; gap: 20px; }
    .reviews-header h3 { font-family: 'Syne', sans-serif; font-size: 2rem; font-weight: 800; color: var(--text); margin: 0; display: flex; align-items: center; gap: 15px; }
