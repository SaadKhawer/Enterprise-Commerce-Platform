@page "/customers"
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<ShopWaveBlazor.Web.ECommerceAPI.Data.ECommerceDbContext> DbFactory
@inject NavigationManager Navigation

<PageTitle>ShopWave — Customers</PageTitle>

<div class="page-header">
    <div>
        <h2>Customers</h2>
        <div class="breadcrumb">Home <i class="bi bi-chevron-right"></i> <span>Customers</span></div>
    </div>
    <button class="btn btn-primary btn-sm" @onclick="ExportCSV" aria-label="Export customers to CSV">
        <i class="bi bi-download"></i> Export CSV
    </button>
</div>

<!-- STATS -->
<div class="cust-stats-row">
    <div class="cust-stat-card blue">
        <div class="cstat-icon"><i class="bi bi-people-fill"></i></div>
        <div class="cstat-info">
            <span class="cstat-val">@customers.Count</span>
            <span class="cstat-label">Total Customers</span>
        </div>
    </div>
    <div class="cust-stat-card green">
        <div class="cstat-icon"><i class="bi bi-person-check"></i></div>
        <div class="cstat-info">
            <span class="cstat-val">@customers.Count(c => c.UserType == "Customer")</span>
            <span class="cstat-label">Regular Users</span>
        </div>
    </div>
    <div class="cust-stat-card pink">
        <div class="cstat-icon"><i class="bi bi-shield-fill"></i></div>
        <div class="cstat-info">
            <span class="cstat-val">@customers.Count(c => c.UserType == "Admin")</span>
            <span class="cstat-label">Admins</span>
        </div>
    </div>
    <div class="cust-stat-card gold">
        <div class="cstat-icon"><i class="bi bi-graph-up-arrow"></i></div>
        <div class="cstat-info">
            <span class="cstat-val">@newThisMonth</span>
            <span class="cstat-label">New This Month</span>
        </div>
    </div>
</div>

<!-- TOOLBAR -->
<div class="cust-toolbar">
    <div class="cust-search">
        <i class="bi bi-search"></i>
        <input type="text" placeholder="Name, email ya phone se search karein..."
               aria-label="Search customers"
               @bind="searchQuery" @bind:event="oninput" />
    </div>
    <div class="cust-filters">
        <select class="form-control form-control-sm" @bind="filterType" aria-label="Filter by user type">
            <option value="">All Types</option>
            <option value="Customer">Customer</option>
            <option value="Admin">Admin</option>
        </select>
    </div>
</div>

<!-- TABLE -->
@if (isLoading)
{
    <div class="glass-card" style="padding:32px;">
        <div class="skeleton" style="height:48px; border-radius:10px; margin-bottom:12px;"></div>
        @for (int i = 0; i < 6; i++)
        {
            <div class="skeleton" style="height:64px; border-radius:10px; margin-bottom:8px;"></div>
        }
    </div>
}
else if (!filteredCustomers.Any())
{
    <div class="empty-state card">
        <i class="bi bi-people empty-icon" style="font-size:4rem;"></i>
        <h4>Koi customer nahi mila</h4>
        <p>Search ya filter change karein.</p>
    </div>
}
else
{
    <div class="glass-card">
        <div style="overflow-x:auto;">
            <table class="data-table cust-table">
                <thead>
                    <tr>
                        <th>Customer</th>
                        <th>Username</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Type</th>
                        <th>Orders</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in filteredCustomers)
                    {
                        <tr class="@(selectedId == c.UserID ? "row-selected" : "")">
                            <td>
                                <div class="cust-cell">
                                    <div class="cust-avatar" style="background:@GetAvatarColor(c.FullName)">
                                        @(c.FullName?.Length > 0 ? c.FullName[0] : 'U')
                                    </div>
                                    <div>
                                        <span class="cust-name">@c.FullName</span>
                                        <span class="cust-id">ID #@c.UserID.ToString("D4")</span>
                                    </div>
                                </div>
                            </td>
                            <td><span class="username-cell">@@@c.Username</span></td>
                            <td>
                                <span class="email-cell">
                                    @(string.IsNullOrEmpty(c.Email) ? "—" : c.Email)
                                </span>
                            </td>
                            <td>
                                <span class="phone-cell">
                                    @(string.IsNullOrEmpty(c.PhoneNumber) ? "—" : c.PhoneNumber)
                                </span>
                            </td>
                            <td>
                                <span class="badge @(c.UserType == "Admin" ? "badge-info" : "badge-success")">
                                    @(c.UserType == "Admin" ? "🛡 Admin" : "👤 Customer")
                                </span>
                            </td>
                            <td>
                                <span class="orders-count">
                                    @(orderCounts.TryGetValue(c.UserID, out var cnt) ? cnt : 0) orders
                                </span>
                            </td>
                            <td>
                                <div class="action-btns">
                                    <button class="btn btn-ghost btn-sm" title="View Details" aria-label="Toggle details for @c.FullName"
                                            @onclick="() => selectedId = (selectedId == c.UserID ? null : c.UserID)">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                    <button class="btn btn-ghost btn-sm" title="Send Message" aria-label="Send message to @c.FullName">
                                        <i class="bi bi-chat-dots"></i>
                                    </button>
                                    <button class="btn btn-danger btn-sm" title="Delete" aria-label="Delete @c.FullName"
                                            @onclick="() => DeleteConfirm(c.UserID)">
                                        <i class="bi bi-trash3"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>

                        <!-- INLINE DETAIL ROW -->
                        @if (selectedId == c.UserID)
                        {
                            <tr class="detail-row">
                                <td colspan="7">
                                    <div class="cust-detail-panel">
                                        <div class="cdp-section">
                                            <h6><i class="bi bi-person-lines-fill"></i> Profile Info</h6>
                                            <div class="cdp-grid">
                                                <div class="cdp-item">
                                                    <span class="cdp-label">Full Name</span>
                                                    <span class="cdp-val">@c.FullName</span>
                                                </div>
                                                <div class="cdp-item">
                                                    <span class="cdp-label">Username</span>
                                                    <span class="cdp-val">@@@c.Username</span>
                                                </div>
                                                <div class="cdp-item">
                                                    <span class="cdp-label">Email</span>
                                                    <span class="cdp-val">@(c.Email ?? "—")</span>
                                                </div>
                                                <div class="cdp-item">
                                                    <span class="cdp-label">Phone</span>
                                                    <span class="cdp-val">@(c.PhoneNumber ?? "—")</span>
                                                </div>
                                                <div class="cdp-item">
                                                    <span class="cdp-label">Account Type</span>
                                                    <span class="cdp-val">@c.UserType</span>
                                                </div>
                                                <div class="cdp-item">
                                                    <span class="cdp-label">Total Orders</span>
                                                    <span class="cdp-val text-primary">
                                                        @(orderCounts.TryGetValue(c.UserID, out var n) ? n : 0)
                                                    </span>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="cdp-actions">
                                            <button class="btn btn-outline btn-sm">
                                                <i class="bi bi-pencil"></i> Edit
                                            </button>
                                            <button class="btn btn-secondary btn-sm"
                                                    @onclick='() => Navigation.NavigateTo("/orders")'>
                                                <i class="bi bi-bag-check"></i> View Orders
                                            </button>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <!-- PAGINATION INFO -->
        <div class="table-footer">
            <span class="table-count">
                @filteredCustomers.Count() customers dikh rahe hain (total @customers.Count)
            </span>
        </div>
    </div>
}

<!-- DELETE CONFIRM MODAL -->
@if (deleteTargetId != null)
{
    <div class="modal-overlay" @onclick="() => deleteTargetId = null">
        <div class="modal-box" @onclick:stopPropagation="true">
            <div class="modal-icon danger">
                <i class="bi bi-exclamation-triangle-fill"></i>
            </div>
            <h4>Customer Delete Karein?</h4>
            <p>Yeh action undo nahi ho sakti. Is customer ka saara data hamesha ke liye delete ho jayega.</p>
            <div class="modal-actions">
                <button class="btn btn-secondary" @onclick="() => deleteTargetId = null">Cancel</button>
                <button class="btn btn-danger" @onclick="ConfirmDelete">
                    <i class="bi bi-trash3"></i> Delete
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<ShopWaveBlazor.Web.ECommerceAPI.Models.User> customers = new();
    private Dictionary<int, int> orderCounts = new();
    private bool isLoading     = true;
    private string searchQuery = "";
    private string filterType  = "";
    private int? selectedId    = null;
    private int? deleteTargetId = null;
    private int newThisMonth   = 0;

    private IEnumerable<ShopWaveBlazor.Web.ECommerceAPI.Models.User> filteredCustomers =>
        customers.Where(c =>
            (string.IsNullOrEmpty(filterType) || c.UserType == filterType) &&
            (string.IsNullOrEmpty(searchQuery) ||
             (c.FullName?.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ?? false) ||
             (c.Email?.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ?? false) ||
             (c.PhoneNumber?.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ?? false) ||
             (c.Username?.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ?? false)));

    protected override async Task OnInitializedAsync()
    {
        using var Db = await DbFactory.CreateDbContextAsync();
        customers = await Db.Users.ToListAsync();

        var orders = await Db.Orders.ToListAsync();
        orderCounts = orders.GroupBy(o => o.UserID)
                            .ToDictionary(g => g.Key, g => g.Count());

        newThisMonth = Random.Shared.Next(3, 18); 
        isLoading = false;
    }

    private void DeleteConfirm(int id) => deleteTargetId = id;

    private async Task ConfirmDelete()
    {
        if (deleteTargetId == null) return;
        
        using var Db = await DbFactory.CreateDbContextAsync();
        var user = await Db.Users.FirstOrDefaultAsync(c => c.UserID == deleteTargetId);
        if (user != null)
        {
            Db.Users.Remove(user);
            await Db.SaveChangesAsync();
            
            // Local update
            var localUser = customers.FirstOrDefault(c => c.UserID == deleteTargetId);
            if (localUser != null) customers.Remove(localUser);
        }
        deleteTargetId = null;
    }

    private void ExportCSV()
    {
        // Placeholder — wire to JS download in real app
    }

    private string GetAvatarColor(string? name)
    {
        var colors = new[]
        {
            "linear-gradient(135deg,#5b8dee,#7b2ff7)",
            "linear-gradient(135deg,#f06292,#e91e63)",
            "linear-gradient(135deg,#2ec4b6,#11998e)",
            "linear-gradient(135deg,#f4c26a,#f09819)",
            "linear-gradient(135deg,#a18cd1,#fbc2eb)",
        };
        var idx = (name?.Length ?? 0) % colors.Length;
        return colors[idx];
    }
}

<style>
    /* ── STATS ── */
    .cust-stats-row {
        display: grid; grid-template-columns: repeat(4, 1fr);
        gap: 16px; margin-bottom: 24px;
    }
    .cust-stat-card {
        background: var(--surface); border: 1px solid var(--border);
        border-radius: var(--r-xl); padding: 18px 20px;
        display: flex; align-items: center; gap: 16px;
        transition: var(--t);
    }
    .cust-stat-card:hover { border-color: var(--border-light); transform: translateY(-2px); }
    .cstat-icon {
        width: 46px; height: 46px; border-radius: var(--r-md);
        display: grid; place-items: center; font-size: 1.2rem; flex-shrink: 0;
    }
    .cust-stat-card.blue .cstat-icon  { background:rgba(91,141,238,.12); color:var(--primary); }
    .cust-stat-card.green .cstat-icon { background:rgba(46,196,182,.12);  color:var(--success); }
    .cust-stat-card.pink .cstat-icon  { background:rgba(240,98,146,.12);  color:var(--secondary); }
    .cust-stat-card.gold .cstat-icon  { background:rgba(244,162,97,.12);  color:var(--gold); }
    .cstat-val {
        display: block; font-family: 'Syne', sans-serif;
        font-size: 1.7rem; font-weight: 800; color: var(--text); line-height: 1;
    }
    .cstat-label { font-size: .74rem; color: var(--text-muted); }

    /* ── TOOLBAR ── */
    .cust-toolbar {
        display: flex; align-items: center; gap: 12px;
        margin-bottom: 20px; flex-wrap: wrap;
    }
    .cust-search {
        display: flex; align-items: center; gap: 10px;
        background: var(--panel); border: 1px solid var(--border);
        border-radius: var(--r-full); padding: 9px 18px;
        flex: 1; min-width: 260px; transition: var(--t);
    }
    .cust-search:focus-within { border-color: var(--primary); }
    .cust-search i { color: var(--text-muted); }
    .cust-search input {
        background: none; border: none; outline: none;
        color: var(--text); font-family: 'Poppins', sans-serif;
        font-size: .85rem; flex: 1;
    }
    .cust-search input::placeholder { color: var(--text-muted); }
    .cust-filters select { min-width: 140px; }

    /* ── TABLE ── */
    .cust-table tbody tr { transition: var(--t); }
    .cust-table tbody tr:hover { background: rgba(91,141,238,.04); }
    .row-selected { background: rgba(91,141,238,.07) !important; }

    .cust-cell { display: flex; align-items: center; gap: 12px; }
    .cust-avatar {
        width: 36px; height: 36px; border-radius: 50%;
        display: grid; place-items: center;
        font-weight: 800; font-size: .85rem; color: var(--text); flex-shrink: 0;
    }
    .cust-name  { display: block; font-size: .88rem; font-weight: 700; color: var(--text); }
    .cust-id    { display: block; font-size: .7rem; color: var(--text-muted); }
    .username-cell { color: var(--primary); font-size: .82rem; font-family: monospace; }
    .email-cell { font-size: .82rem; color: var(--text-2); }
    .phone-cell { font-size: .82rem; color: var(--text-2); }
    .orders-count { font-size: .82rem; font-weight: 700; color: var(--text-2); }

    .action-btns { display: flex; gap: 6px; align-items: center; }

    /* ── DETAIL ROW ── */
    .detail-row td { padding: 0 !important; background: var(--panel); }
    .cust-detail-panel {
        padding: 20px 24px;
        border-top: 1px solid var(--border);
        animation: slideDown .2s ease;
        display: flex; align-items: flex-start;
        justify-content: space-between; gap: 24px; flex-wrap: wrap;
    }
    @@keyframes slideDown { from{opacity:0;transform:translateY(-6px)} to{opacity:1;transform:none} }
    .cdp-section h6 {
        font-size: .72rem; text-transform: uppercase; letter-spacing: 1px;
        color: var(--text-muted); font-weight: 700; margin-bottom: 14px;
        display: flex; align-items: center; gap: 7px;
    }
    .cdp-grid {
        display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px;
    }
    .cdp-item { display: flex; flex-direction: column; gap: 3px; }
    .cdp-label { font-size: .68rem; text-transform: uppercase; letter-spacing: .8px; color: var(--text-muted); font-weight: 700; }
    .cdp-val   { font-size: .85rem; color: var(--text); font-weight: 600; }
    .cdp-actions { display: flex; flex-direction: column; gap: 8px; justify-content: flex-start; }

    /* ── TABLE FOOTER ── */
    .table-footer {
        padding: 14px 20px; border-top: 1px solid var(--border);
        font-size: .78rem; color: var(--text-muted);
    }

    /* ── DELETE MODAL ── */
    .modal-overlay {
        position: fixed; inset: 0; z-index: 1000;
        background: rgba(7,8,15,.75); backdrop-filter: blur(4px);
        display: flex; align-items: center; justify-content: center;
    }
    .modal-box {
        background: var(--surface); border: 1px solid var(--border);
        border-radius: var(--r-xl); padding: 36px 40px;
        max-width: 400px; width: 100%; text-align: center;
        animation: modalPop .25s cubic-bezier(.175,.885,.32,1.275);
    }
    @@keyframes modalPop { from{transform:scale(.9);opacity:0} to{transform:scale(1);opacity:1} }
    .modal-icon {
        font-size: 2.8rem; margin-bottom: 16px;
    }
    .modal-icon.danger { color: var(--danger); }
    .modal-box h4 { font-family:'Syne',sans-serif; font-weight:800; color: var(--text); margin-bottom:10px; }
    .modal-box p  { color:var(--text-2); font-size:.88rem; line-height:1.7; margin-bottom:24px; }
    .modal-actions { display:flex; gap:12px; justify-content:center; }
</style>

