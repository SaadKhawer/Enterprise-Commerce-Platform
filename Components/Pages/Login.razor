@page "/login"
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@inject IDbContextFactory<ShopWaveBlazor.Web.ECommerceAPI.Data.ECommerceDbContext> DbFactory
@inject ShopWaveBlazor.Web.Services.AuthService AuthService
@inject NavigationManager Navigation
@inject ProtectedLocalStorage LocalStorage
@layout ShopWaveBlazor.Web.Components.Layout.EmptyLayout

<PageTitle>ShopPK — Login</PageTitle>

<div class="login-container">
    <div class="bg"></div>
    <div class="bg-grid"></div>
    <div class="orb orb1"></div>
    <div class="orb orb2"></div>

    <div class="wrapper">
        <!-- LEFT BRAND PANEL -->
        <div class="brand">
            <div class="logo" style="display: flex; align-items: center; gap: 15px;">
                <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcT7QnjcTUOpzRq05tWsyO5NYOmThuRS-5estg&s" alt="Logo" style="height: 50px; width: 50px; border-radius: 50%; object-fit: cover;" />
                <div>Shop<span>PK</span></div>
            </div>
            <div class="logo-sub">Pakistan's Premium Store</div>

            <h2 class="tagline">Shop Smart,<br><em>Live Better.</em></h2>
            <p class="tagline-sub">Pakistan's most trusted e-commerce platform. Electronics, clothing, books and more — all in one place.</p>

            <div class="features">
                <div class="feat">
                    <div class="feat-icon blue"><i class="bi bi-truck"></i></div>
                    <div class="feat-text">
                        <strong>Fast Delivery</strong>
                        <span>Standard (5-7 days) · Express (2-3 days)</span>
                    </div>
                </div>
                <div class="feat">
                    <div class="feat-icon pink"><i class="bi bi-credit-card"></i></div>
                    <div class="feat-text">
                        <strong>Multiple Payments</strong>
                        <span>JazzCash · EasyPaisa · Card · COD</span>
                    </div>
                </div>
                <div class="feat">
                    <div class="feat-icon gold"><i class="bi bi-patch-check"></i></div>
                    <div class="feat-text">
                        <strong>Verified Reviews</strong>
                        <span>Only verified customers can leave reviews</span>
                    </div>
                </div>
            </div>

            <div class="brand-decor">
                <div class="brand-decor-inner"></div>
                <i class="bi bi-cart3"></i>
            </div>
        </div>

        <!-- RIGHT FORM PANEL -->
        <div class="form-panel">
            <div class="form-box">
                <h1 class="form-title">
                    @(activeTab == "admin" ? "Admin Portal" : "Welcome Back")
                </h1>
                <p class="form-subtitle">
                    @(activeTab == "admin" ? "Authorized access only" : "Log in to your account")
                </p>

                <div class="tab-row">
                    <button class="tab @(activeTab == "login" ? "active" : "")" @onclick='() => SetTab("login")'>Login</button>
                    <button class="tab @(activeTab == "admin" ? "active" : "")" @onclick='() => SetTab("admin")'>Admin</button>
                    <button class="tab" @onclick='() => SetTab("register")'>Register</button>
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert error">
                        <i class="bi bi-exclamation-triangle-fill"></i> @errorMessage
                    </div>
                }
                
                @if (loginSuccess)
                {
                    <div class="alert success">
                        <i class="bi bi-check-circle-fill"></i> Login successful! Redirecting...
                    </div>
                }

                <form @onsubmit="HandleLogin" @onsubmit:preventDefault>
                    <div class="form-group">
                        <label class="form-label">Username</label>
                        <div class="input-wrap">
                            <span class="input-icon"><i class="bi bi-person"></i></span>
                            <input type="text" class="form-input" placeholder="Enter username" @bind="username" autocomplete="username">
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Password</label>
                        <div class="input-wrap">
                            <span class="input-icon"><i class="bi bi-lock"></i></span>
                            <input type="@(showPassword ? "text" : "password")" class="form-input" placeholder="Enter password" @bind="password" autocomplete="current-password">
                            <button type="button" class="eye-btn" @onclick="() => showPassword = !showPassword">
                                <i class="bi @(showPassword ? "bi-eye-slash" : "bi-eye")"></i>
                            </button>
                        </div>
                    </div>

                    <div class="row-between">
                        <label class="remember">
                            <input type="checkbox" @bind="rememberMe">
                            <span>Remember me</span>
                        </label>
                        <a href="#" class="forgot">Forgot password?</a>
                    </div>

                    <button type="submit" class="btn-login" disabled="@isProcessing">
                        @if (isProcessing)
                        {
                            <span class="spinner"></span> <span>Checking...</span>
                        }
                        else if (loginSuccess)
                        {
                            <i class="bi bi-check2"></i> <span>Success</span>
                        }
                        else
                        {
                            <span>Login Now</span>
                        }
                    </button>
                    <div style="text-align: center; margin-top: 16px; font-size: 0.85rem; color: var(--muted);">
                        Don't have an account? <a href="/register" style="color: var(--accent-text); font-weight: 600; text-decoration: none;">Register Now</a>
                    </div>
                </form>

                <div class="divider"><span>Or quick login</span></div>

                <div class="quick-btns">
                    <button class="quick-btn" @onclick='() => QuickFill("customer", "customer123")'>
                        <strong>Demo Customer</strong>
                        <i class="bi bi-person-circle"></i> customer
                    </button>
                    <button class="quick-btn" @onclick='() => QuickFill("admin", "admin123")'>
                        <strong>Demo Admin</strong>
                        <i class="bi bi-shield-lock"></i> admin
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string username = "";
    private string password = "";
    private string activeTab = "login";
    private bool rememberMe;
    private bool showPassword;
    private string? errorMessage;
    private bool isProcessing;
    private bool loginSuccess;

    private void SetTab(string tab)
    {
        if (tab == "register")
        {
            Navigation.NavigateTo("/register");
        }
        else
        {
            activeTab = tab;
            errorMessage = null;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var result = await LocalStorage.GetAsync<string>("savedUsername");
            if (result.Success && !string.IsNullOrEmpty(result.Value))
            {
                username = result.Value;
                rememberMe = true;
                StateHasChanged();
            }
        }
    }

    private void QuickFill(string u, string p)
    {
        username = u;
        password = p;
        activeTab = u == "admin" ? "admin" : "login";
        errorMessage = null;
    }

    private async Task HandleLogin()
    {
        if (string.IsNullOrWhiteSpace(username))
        {
            errorMessage = "Please enter your username.";
            return;
        }
        if (password.Length < 6)
        {
            errorMessage = "Password must be at least 6 characters.";
            return;
        }

        isProcessing = true;
        errorMessage = null;
        StateHasChanged();

        bool success = await AuthService.LoginAsync(username, password);
        
        if (success)
        {
            // Verify role if in Admin tab
            if (activeTab == "admin" && !AuthService.IsAdmin)
            {
                AuthService.Logout();
                errorMessage = "This account does not have Admin privileges.";
                isProcessing = false;
                return;
            }

            loginSuccess = true;
            if (rememberMe)
                await LocalStorage.SetAsync("savedUsername", username);
            else
                await LocalStorage.DeleteAsync("savedUsername");

            // Store UserID for session persistence across refreshes
            await LocalStorage.SetAsync("userId", AuthService.CurrentUser!.UserID);
            
            StateHasChanged();
            await Task.Delay(1000);
            Navigation.NavigateTo(AuthService.IsAdmin ? "/dashboard" : "/", forceLoad: true);
        }
        else
        {
            errorMessage = "Invalid username or password. Please try again.";
            isProcessing = false;
        }
    }
}

<style>
    .login-container {
        --bg: #F6F6F7;
        --surface: #FFFFFF;
        --panel: rgba(0,0,0,0.03);
        --border: rgba(0,0,0,0.08);
        --accent: #D9F86B;
        --accent-text: #4d7c0f;
        --accent2: #111018;
        --gold: #6B7280;
        --text: #111018;
        --muted: #6B7280;
        --success: #10B981;
        --error: #EF4444;

        position: fixed; inset: 0;
        font-family: 'DM Sans', sans-serif;
        background: var(--bg);
        color: var(--text);
        overflow: hidden;
        z-index: 999;
    }

    /* ── ANIMATED BACKGROUND ── */
    .bg {
        position: absolute; inset: 0; z-index: 0;
        background:
            radial-gradient(ellipse 80% 60% at 0% 0%, rgba(91,141,238,.13) 0%, transparent 60%),
            radial-gradient(ellipse 60% 50% at 100% 100%, rgba(240,98,146,.10) 0%, transparent 60%),
            var(--bg);
    }
    .bg-grid {
        position: absolute; inset: 0; z-index: 0;
        background-image:
            linear-gradient(rgba(91,141,238,.04) 1px, transparent 1px),
            linear-gradient(90deg, rgba(91,141,238,.04) 1px, transparent 1px);
        background-size: 44px 44px;
    }
    .orb {
        position: absolute; border-radius: 50%; z-index: 0;
        filter: blur(80px); opacity: 0.5;
        animation: float-login 10s ease-in-out infinite alternate;
    }
    .orb1 { width:400px; height:400px; top:-100px; left:-80px; background:rgba(91,141,238,.18); }
    .orb2 { width:300px; height:300px; bottom:-60px; right:-60px; background:rgba(240,98,146,.14); animation-delay:-5s; }
    
    @@keyframes float-login { 
        from{transform:translate(0,0) scale(1)} 
        to{transform:translate(25px,35px) scale(1.06)} 
    }

    /* ── LAYOUT ── */
    .wrapper {
        position: relative; z-index: 1;
        height: 100vh;
        display: grid;
        grid-template-columns: 1fr 1fr;
    }

    /* ── LEFT BRAND PANEL ── */
    .brand {
        padding: 60px;
        display: flex; flex-direction: column; justify-content: center;
        border-right: 1px solid var(--border);
        position: relative; overflow: hidden;
    }
    .brand::before {
        content: '';
        position: absolute; inset: 0;
        background: repeating-linear-gradient(
            -45deg,
            transparent, transparent 30px,
            rgba(91,141,238,.025) 30px, rgba(91,141,238,.025) 31px
        );
    }
    .logo {
        font-family: 'Syne', sans-serif;
        font-size: 2.8rem; font-weight: 800;
        letter-spacing: -2px;
        line-height: 1;
        margin-bottom: 6px;
        position: relative;
    }
    .logo span { color: var(--accent-text); }
    .logo-sub { color: var(--gold); font-size: 0.7rem; letter-spacing: 4px; text-transform:uppercase; margin-bottom: 48px; }

    .tagline {
        font-family: 'Syne', sans-serif;
        font-size: 1.6rem; font-weight: 700;
        line-height: 1.35;
        margin-bottom: 12px;
        color: var(--text);
    }
    .tagline em { font-style: normal; color: var(--accent-text); }
    .tagline-sub { color: var(--muted); font-size: 0.9rem; line-height: 1.6; margin-bottom: 48px; max-width: 320px; }

    .features { display: flex; flex-direction: column; gap: 16px; }
    .feat {
        display: flex; align-items: center; gap: 14px;
        padding: 14px 18px;
        background: rgba(0,0,0,0.03);
        border: 1px solid var(--border);
        border-radius: 12px;
        transition: border-color .3s, background .3s;
        animation: fadeIn-login .5s ease both;
    }
    .feat:hover { border-color: rgba(91,141,238,.3); background: rgba(91,141,238,.05); }
    .feat:nth-child(1){ animation-delay:.1s }
    .feat:nth-child(2){ animation-delay:.2s }
    .feat:nth-child(3){ animation-delay:.3s }
    .feat-icon {
        width: 38px; height: 38px; border-radius: 10px;
        display: grid; place-items: center; font-size: 1.1rem; flex-shrink:0;
        background: rgba(0,0,0,0.05); color: #111018;
    }
    .feat-text strong { display:block; font-size:.85rem; font-weight:500; margin-bottom:2px; color: var(--text); }
    .feat-text span { color: var(--muted); font-size:.78rem; }

    .brand-decor {
        position: absolute; bottom: 40px; right: 40px;
        width: 100px; height: 100px;
        border: 1.5px solid var(--border);
        border-radius: 50%;
        display: grid; place-items: center;
        font-size: 2.2rem;
        opacity: 0.6;
        animation: spin-login 20s linear infinite;
        color: var(--accent);
    }
    @@keyframes spin-login { to { transform: rotate(360deg); } }
    .brand-decor-inner {
        position: absolute; width: 70px; height: 70px;
        border: 1.5px solid rgba(91,141,238,.3);
        border-radius: 50%;
        animation: spin-login 10s linear infinite reverse;
    }

    /* ── RIGHT FORM PANEL ── */
    .form-panel {
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        padding: 60px 70px;
    }
    .form-box {
        width: 100%; max-width: 380px;
        animation: slideUp-login .5s ease;
    }
    @@keyframes slideUp-login { from{opacity:0;transform:translateY(20px)} to{opacity:1;transform:translateY(0)} }
    @@keyframes fadeIn-login  { from{opacity:0;transform:translateX(-10px)} to{opacity:1;transform:translateX(0)} }

    .form-title {
        font-family: 'Syne', sans-serif;
        font-size: 2rem; font-weight: 800;
        margin-bottom: 6px; letter-spacing: -1px;
        color: var(--text);
    }
    .form-subtitle { color: var(--muted); font-size: .88rem; margin-bottom: 36px; }

    .tab-row {
        display: flex; gap: 4px;
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 10px; padding: 4px;
        margin-bottom: 28px;
    }
    .tab {
        flex:1; padding: 9px;
        border-radius: 8px; border: none;
        background: transparent; color: var(--muted);
        font-family: 'DM Sans', sans-serif; font-size: .85rem;
        cursor: pointer; transition: .2s;
    }
    .tab.active {
        background: #111018; color: #FFFFFF;
        font-weight: 500;
        box-shadow: 0 4px 10px rgba(0,0,0,.15);
    }

    .form-group { margin-bottom: 18px; }
    .form-label { display:block; font-size:.78rem; font-weight:500; color: var(--muted); margin-bottom: 8px; letter-spacing:.5px; text-transform:uppercase; }
    .input-wrap { position: relative; }
    .input-icon {
        position: absolute; left: 14px; top: 50%; transform: translateY(-50%);
        color: var(--muted); font-size: 1.1rem; pointer-events:none;
    }
    .form-input {
        width: 100%; padding: 13px 14px 13px 42px;
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 10px;
        color: var(--text);
        font-family: 'DM Sans', sans-serif; font-size: .9rem;
        outline: none; transition: border-color .2s, box-shadow .2s;
    }
    .form-input:focus {
        border-color: var(--accent);
        box-shadow: 0 0 0 3px rgba(91,141,238,.15);
    }
    .form-input::placeholder { color: var(--muted); }
    .eye-btn {
        position: absolute; right: 12px; top: 50%; transform: translateY(-50%);
        background: none; border: none; color: var(--muted);
        cursor: pointer; font-size: 1.1rem; padding: 4px;
        transition: color .2s;
    }
    .eye-btn:hover { color: var(--text); }

    .row-between {
        display: flex; align-items: center; justify-content: space-between;
        margin-bottom: 24px; margin-top: -4px;
    }
    .remember { display:flex; align-items:center; gap:8px; cursor:pointer; }
    .remember input { accent-color: var(--accent); width:14px; height:14px; }
    .remember span { font-size:.82rem; color: var(--muted); }
    .forgot { font-size:.82rem; color: var(--accent-text); font-weight: 600; text-decoration:none; transition: opacity .2s; }
    .forgot:hover { opacity:.7; text-decoration:underline; }

    .btn-login {
        width: 100%; padding: 14px;
        background: var(--accent);
        border: none; border-radius: 10px;
        color: #111018; font-family: 'DM Sans', sans-serif;
        font-size: .95rem; font-weight: 700;
        cursor: pointer; transition: opacity .2s, transform .15s, box-shadow .2s;
        box-shadow: 0 4px 10px rgba(0,0,0,.1);
        letter-spacing: .3px;
        display: flex; align-items: center; justify-content: center; gap: 10px;
    }
    .btn-login:hover { opacity: .9; transform: translateY(-1px); box-shadow: 0 6px 15px rgba(0,0,0,.15); }
    .btn-login:active { transform: translateY(0); }
    .btn-login:disabled { opacity:.5; cursor:not-allowed; transform:none; }

    .divider { display:flex; align-items:center; gap:12px; margin: 20px 0; }
    .divider::before, .divider::after { content:''; flex:1; height:1px; background: var(--border); }
    .divider span { color: var(--muted); font-size: .78rem; white-space:nowrap; }

    .quick-btns { display:flex; gap:8px; }
    .quick-btn {
        flex:1; padding: 10px;
        background: var(--panel); border: 1px solid var(--border);
        border-radius: 10px; color: var(--text);
        font-family: 'DM Sans', sans-serif; font-size: .78rem;
        cursor: pointer; transition: .2s; text-align:center;
    }
    .quick-btn:hover { border-color: var(--accent); background: var(--accent); }
    .quick-btn strong { display:block; font-size:.72rem; color: var(--text); margin-bottom:2px; font-weight:600; }

    .alert {
        padding: 12px 16px; border-radius: 10px;
        font-size: .84rem; margin-bottom: 16px;
        display: flex; align-items: center; gap: 10px;
    }
    .alert.error  { background: rgba(240,98,146,.1); border: 1px solid rgba(240,98,146,.3); color: var(--error); }
    .alert.success{ background: rgba(86,207,130,.1); border: 1px solid rgba(86,207,130,.3); color: var(--success); }

    .spinner {
        display: inline-block; width:16px; height:16px;
        border:2px solid rgba(0,0,0,0.3);
        border-top-color: var(--text); border-radius:50%;
        animation: spin-login .6s linear infinite;
    }

    @@media(max-width:768px){
        .wrapper { grid-template-columns: 1fr; }
        .brand { display:none; }
        .form-panel { padding: 40px 28px; }
        .login-container { overflow-y: auto; }
    }
</style>

