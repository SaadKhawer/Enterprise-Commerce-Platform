<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    
    <!-- Premium Google Fonts: Syne (Display), DM Sans (Body), JetBrains Mono (Data) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/app.css" />
    
    <!-- Chart.js for Dashboard -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <!-- PDF Generation -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    
    <HeadOutlet />
</head>

<body>
    <Routes @rendermode="InteractiveServer" />
    <script src="_framework/blazor.web.js"></script>
    
    <script>
        window.scrollToElement = (id) => {
            const el = document.getElementById(id);
            if (el) {
                el.scrollIntoView({ behavior: 'smooth' });
            }
        };
        window.downloadFile = (filename, content) => {
            const blob = new Blob([content], { type: 'text/csv;charset=utf-8;' });
            const link = document.createElement('a');
            const url = URL.createObjectURL(blob);
            link.setAttribute('href', url);
            link.setAttribute('download', filename);
            link.style.visibility = 'hidden';
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        };
        window.generatePDF = (elementId, filename) => {
            console.log("Generating PDF for element: " + elementId);
            const element = document.getElementById(elementId);
            if (!element) {
                console.error("Element not found: " + elementId);
                return;
            }

            try {
                if (typeof html2pdf !== 'undefined') {
                    console.log("Using html2pdf.js engine...");
                    const opt = {
                        margin:       [8, 8, 8, 8],
                        filename:     filename,
                        image:        { type: 'jpeg', quality: 0.98 },
                        html2canvas:  { 
                            scale: 2, 
                            useCORS: true,
                            backgroundColor: '#080C14', // Match the luxury dark theme background
                            logging: false
                        },
                        jsPDF:        { unit: 'mm', format: 'a4', orientation: 'landscape' }, // Landscape fits wide dashboards beautifully
                        pagebreak:    { mode: ['avoid-all', 'css'] }
                    };

                    element.style.padding = '10px';
                    html2pdf().set(opt).from(element).save().then(() => {
                        element.style.padding = '';
                        console.log("PDF generated successfully via html2pdf.");
                    }).catch(err => {
                        console.warn("html2pdf generation failed, falling back to window.print:", err);
                        element.style.padding = '';
                        window.print();
                    });
                } else {
                    console.warn("html2pdf library is undefined. Falling back to native browser print...");
                    window.print();
                }
            } catch (e) {
                console.error("PDF generation exception, falling back to window.print:", e);
                window.print();
            }
        };

        /* ── Animated Count-Up ── */
        window.animateCountUp = (elementId, endVal, duration, prefix, suffix) => {
            const el = document.getElementById(elementId);
            if (!el) return;
            const start = 0;
            const startTime = performance.now();
            const fmt = (n) => n.toLocaleString('en-US');
            const step = (now) => {
                const elapsed = now - startTime;
                const progress = Math.min(elapsed / duration, 1);
                const ease = 1 - Math.pow(1 - progress, 3); // easeOutCubic
                const current = Math.floor(start + (endVal - start) * ease);
                el.textContent = (prefix || '') + fmt(current) + (suffix || '');
                if (progress < 1) requestAnimationFrame(step);
            };
            requestAnimationFrame(step);
        };

        /* ── Sparkline Mini Charts (Canvas) ── */
        window.drawSparkline = (canvasId, dataPoints, color) => {
            const canvas = document.getElementById(canvasId);
            if (!canvas) return;
            const ctx = canvas.getContext('2d');
            const w = canvas.width = canvas.offsetWidth * 2;
            const h = canvas.height = canvas.offsetHeight * 2;
            ctx.scale(2, 2);
            const cw = canvas.offsetWidth;
            const ch = canvas.offsetHeight;
            const max = Math.max(...dataPoints);
            const min = Math.min(...dataPoints);
            const range = max - min || 1;
            const pad = 2;
            const stepX = (cw - pad * 2) / (dataPoints.length - 1);

            ctx.clearRect(0, 0, cw, ch);
            ctx.beginPath();
            dataPoints.forEach((v, i) => {
                const x = pad + i * stepX;
                const y = ch - pad - ((v - min) / range) * (ch - pad * 2);
                i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
            });
            ctx.strokeStyle = color;
            ctx.lineWidth = 1.5;
            ctx.lineJoin = 'round';
            ctx.lineCap = 'round';
            ctx.stroke();

            // gradient fill
            const last = dataPoints.length - 1;
            ctx.lineTo(pad + last * stepX, ch);
            ctx.lineTo(pad, ch);
            ctx.closePath();
            const grad = ctx.createLinearGradient(0, 0, 0, ch);
            grad.addColorStop(0, color.replace(')', ',0.25)').replace('rgb', 'rgba'));
            grad.addColorStop(1, 'transparent');
            ctx.fillStyle = grad;
            ctx.fill();
        };

        /* ── Chart.js Revenue Area Chart ── */
        window._chartInstances = window._chartInstances || {};
        window.renderRevenueChart = (canvasId, labels, data) => {
            const canvas = document.getElementById(canvasId);
            if (!canvas) return;
            if (window._chartInstances[canvasId]) {
                window._chartInstances[canvasId].destroy();
            }
            const ctx = canvas.getContext('2d');
            const gradient = ctx.createLinearGradient(0, 0, 0, canvas.parentElement.offsetHeight);
            gradient.addColorStop(0, 'rgba(79, 142, 247, 0.35)');
            gradient.addColorStop(0.5, 'rgba(79, 142, 247, 0.08)');
            gradient.addColorStop(1, 'rgba(79, 142, 247, 0)');

            window._chartInstances[canvasId] = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Revenue (Rs.)',
                        data: data,
                        borderColor: '#4F8EF7',
                        borderWidth: 2.5,
                        backgroundColor: gradient,
                        fill: true,
                        tension: 0.4,
                        pointBackgroundColor: '#4F8EF7',
                        pointBorderColor: '#080C14',
                        pointBorderWidth: 2,
                        pointRadius: 4,
                        pointHoverRadius: 7,
                        pointHoverBackgroundColor: '#fff',
                        pointHoverBorderColor: '#4F8EF7',
                        pointHoverBorderWidth: 3,
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    animation: { duration: 1200, easing: 'easeOutCubic' },
                    interaction: { intersect: false, mode: 'index' },
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: '#0F1623',
                            borderColor: 'rgba(0,0,0,0.1)',
                            borderWidth: 1,
                            titleColor: '#F0F4FF',
                            bodyColor: '#A0AECB',
                            titleFont: { family: 'DM Sans', weight: '700', size: 13 },
                            bodyFont: { family: 'JetBrains Mono', size: 12 },
                            padding: 12,
                            cornerRadius: 10,
                            displayColors: false,
                            callbacks: {
                                label: (ctx) => 'Rs. ' + ctx.parsed.y.toLocaleString()
                            }
                        }
                    },
                    scales: {
                        x: {
                            grid: { color: 'rgba(0,0,0,0.04)', drawBorder: false },
                            ticks: { color: '#6B7A99', font: { family: 'DM Sans', size: 11 } },
                            border: { display: false }
                        },
                        y: {
                            grid: { color: 'rgba(0,0,0,0.04)', drawBorder: false },
                            ticks: {
                                color: '#6B7A99',
                                font: { family: 'JetBrains Mono', size: 11 },
                                callback: (v) => v >= 1000 ? (v/1000) + 'K' : v
                            },
                            border: { display: false },
                            beginAtZero: true
                        }
                    }
                }
            });
        };

        /* ── Chart.js for Reports Revenue Trend ── */
        window.renderReportsChart = (canvasId, labels, data) => {
            window.renderRevenueChart(canvasId, labels, data);
        };

        /* ── Command Palette (Cmd+K) ── */
        document.addEventListener('keydown', (e) => {
            if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
                e.preventDefault();
                const palette = document.getElementById('command-palette');
                if (palette) {
                    palette.classList.toggle('open');
                    const input = palette.querySelector('input');
                    if (input) input.focus();
                }
            }
            if (e.key === 'Escape') {
                const palette = document.getElementById('command-palette');
                if (palette) palette.classList.remove('open');
            }
        });

        /* ── Live Clock ── */
        window.startClock = (elementId) => {
            const el = document.getElementById(elementId);
            if (!el) return;
            const update = () => {
                const now = new Date();
                const h = now.getHours().toString().padStart(2, '0');
                const m = now.getMinutes().toString().padStart(2, '0');
                const s = now.getSeconds().toString().padStart(2, '0');
                el.textContent = `${h}:${m}:${s}`;
            };
            update();
            setInterval(update, 1000);
        };
    </script>
</body>

</html>

