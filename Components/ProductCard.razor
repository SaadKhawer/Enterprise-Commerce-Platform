@inject NavigationManager Navigation
@using ShopWaveBlazor.Web.ECommerceAPI.Models
@using ShopWaveBlazor.Web.Services

<div class="product-card-v2 @(Product.StockQuantity == 0 ? "out-of-stock" : "")" @onclick="NavigateToDetails">
    <!-- BADGE -->
    @if (Product.StockQuantity == 0)
    {
        <div class="badge-pill badge-sold-out">Sold Out</div>
    }
    else if (Product.Price > 100000)
    {
        <div class="badge-pill badge-new">New</div>
    }
    else
    {
        <div class="badge-pill badge-sale">Sale</div>
    }

    <!-- WISHLIST -->
    <button class="wishlist-floating" aria-label="Add to wishlist" @onclick:stopPropagation="true" @onclick="OnToggleWishlist">
        <i class="bi @(isWishlisted ? "bi-heart-fill wishlisted" : "bi-heart")"></i>
    </button>

    <!-- IMAGE -->
    <div class="card-img-wrap-v2">
        <img src="@ProductImageService.GetImage(Product.ProductName, Product.Category?.CategoryName)"
             class="card-img-v2"
             alt="@Product.ProductName"
             onerror="this.src='https://images.unsplash.com/photo-1560472355-536de3962603?w=400&q=80'" />
    </div>

    <!-- BODY -->
    <div class="card-body-v2">
        <span class="category-chip">@(Product.Category?.CategoryName?.ToUpper() ?? "GENERAL")</span>
        <h4 class="product-name-v2" title="@Product.ProductName">@Product.ProductName</h4>
        <p class="product-desc-v2">@(string.IsNullOrEmpty(Product.Description) ? "Premium quality product." : Product.Description)</p>
        
        <div class="rating-row-v2">
            <span class="stars-v2">★★★★½</span>
            <span class="rating-count-v2">(@(Product.Rating > 0 ? Product.Rating.ToString("0.0") : "4.5")) · @(Product.TotalReviews > 0 ? Product.TotalReviews : 120) sold</span>
        </div>

        <div class="price-row-v2">
            <div class="price-left">
                <span class="price-current">Rs. @Product.Price.ToString("N0")</span>
                <span class="price-old">Rs. @((Product.Price * 1.2m).ToString("N0"))</span>
            </div>
            <span class="discount-badge">-20%</span>
        </div>
    </div>

    <!-- FOOTER / BUTTON -->
    <div class="card-footer-v2">
        <button class="btn-add-cart-v2" 
                disabled="@(Product.StockQuantity == 0)"
                @onclick:stopPropagation="true"
                @onclick="OnAddToCart">
            @if(Product.StockQuantity == 0) {
                <i class="bi bi-cart-x"></i> <span>Out of Stock</span>
            } else {
                <i class="bi bi-cart-plus"></i> <span>Add to Cart</span>
            }
        </button>
        <button class="btn-quick-view-v2" @onclick:stopPropagation="true" @onclick="NavigateToDetails">
            <i class="bi bi-eye"></i>
        </button>
    </div>
</div>

@code {
    [Parameter] public Product Product { get; set; } = new();
    [Parameter] public EventCallback<Product> OnAddToCartClick { get; set; }

    private bool isWishlisted = false;

    private void NavigateToDetails() =>
        Navigation.NavigateTo($"/product/{Product.ProductID}");

    private async Task OnAddToCart() =>
        await OnAddToCartClick.InvokeAsync(Product);

    private void OnToggleWishlist() => isWishlisted = !isWishlisted;
}

<style>
    .product-card-v2 {
        background: var(--surface);
        border-radius: 16px;
        border: 1px solid rgba(0,0,0,0.08);
        box-shadow: 0 4px 24px rgba(0,0,0,0.3);
        overflow: hidden;
        position: relative;
        display: flex;
        flex-direction: column;
        transition: all 0.3s ease;
        cursor: pointer;
        height: 100%;
        min-height: 480px;
    }
    
    .product-card-v2:hover {
        transform: translateY(-6px);
        border-color: rgba(91,141,238,0.5);
        box-shadow: 0 12px 30px rgba(91,141,238,0.15);
    }

    /* BADGES */
    .badge-pill {
        position: absolute; top: 12px; left: 12px; z-index: 10;
        padding: 4px 12px; border-radius: 20px;
        font-size: 0.75rem; font-weight: 700; color: var(--text);
        letter-spacing: 0.5px; text-transform: uppercase;
    }
    .badge-new { background: linear-gradient(135deg, #5b8dee, #3b6bce); }
    .badge-sale { background: linear-gradient(135deg, #2ec4b6, #1c9e92); }
    .badge-sold-out { background: linear-gradient(135deg, #e63946, #c1121f); }

    .wishlist-floating {
        position: absolute; top: 12px; right: 12px; z-index: 10;
        width: 34px; height: 34px; border-radius: 50%;
        background: rgba(15,23,41,0.6); backdrop-filter: blur(4px);
        border: 1px solid rgba(0,0,0,0.1);
        color: var(--text); cursor: pointer; display: grid; place-items: center;
        transition: all 0.2s; font-size: 1rem;
    }
    .wishlist-floating:hover { background: rgba(15,23,41,0.9); transform: scale(1.1); }
    .wishlisted { color: #f06292 !important; }

    /* IMAGE */
    .card-img-wrap-v2 {
        width: 100%; height: 220px; overflow: hidden;
        background: linear-gradient(180deg, #161c2d 0%, #0f1729 100%);
        position: relative; flex-shrink: 0;
    }
    .card-img-v2 {
        width: 100%; height: 100%;
        object-fit: cover; object-position: center;
        transition: transform 0.5s ease;
    }
    .product-card-v2:hover .card-img-v2 {
        transform: scale(1.05);
    }

    /* BODY */
    .card-body-v2 {
        padding: 20px;
        display: flex; flex-direction: column; flex: 1;
    }
    .category-chip {
        font-size: 0.7rem; font-weight: 700; color: #5b8dee;
        letter-spacing: 1px; margin-bottom: 8px; display: block;
    }
    .product-name-v2 {
        font-size: 16px; font-weight: 700; color: var(--text);
        margin-bottom: 6px; line-height: 1.4;
        display: -webkit-box; -webkit-line-clamp: 2;
        -webkit-box-orient: vertical; overflow: hidden;
    }
    .product-desc-v2 {
        font-size: 0.8rem; color: #8a8d9e;
        margin-bottom: 12px; line-height: 1.5;
        display: -webkit-box; -webkit-line-clamp: 2;
        -webkit-box-orient: vertical; overflow: hidden;
    }

    /* RATING */
    .rating-row-v2 {
        display: flex; align-items: center; gap: 8px;
        margin-bottom: 15px; margin-top: auto;
    }
    .stars-v2 { color: #f4a261; font-size: 0.9rem; letter-spacing: 2px; }
    .rating-count-v2 { font-size: 0.75rem; color: #8a8d9e; font-weight: 500; }

    /* PRICE */
    .price-row-v2 {
        display: flex; justify-content: space-between; align-items: center;
    }
    .price-left { display: flex; flex-direction: column; }
    .price-current { font-size: 1.25rem; font-weight: 800; color: var(--text); line-height: 1.2; }
    .price-old { font-size: 0.85rem; color: #6c7293; text-decoration: line-through; }
    .discount-badge {
        background: rgba(46,196,182,0.15); border: 1px solid rgba(46,196,182,0.3);
        color: #2ec4b6; font-size: 0.75rem; font-weight: 700;
        padding: 4px 8px; border-radius: 6px;
    }

    /* FOOTER */
    .card-footer-v2 {
        padding: 0 20px 20px 20px;
        display: flex; gap: 10px;
    }
    .btn-add-cart-v2 {
        flex: 1; height: 44px; border: none; border-radius: 10px;
        background: #111018;
        color: #FFFFFF; font-weight: 600; font-size: 0.95rem;
        display: flex; justify-content: center; align-items: center; gap: 8px;
        transition: all 0.3s ease; cursor: pointer;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }
    .btn-add-cart-v2:hover:not(:disabled) {
        transform: translateY(-2px); box-shadow: 0 6px 15px rgba(0,0,0,0.2);
    }
    .btn-add-cart-v2:disabled {
        background: rgba(230,57,70,0.1); color: #e63946; cursor: not-allowed;
        border: 1px solid rgba(230,57,70,0.3); box-shadow: none;
    }
    .btn-quick-view-v2 {
        width: 44px; height: 44px; border: 1px solid rgba(0,0,0,0.1);
        border-radius: 10px; background: rgba(0,0,0,0.05);
        color: var(--text); display: grid; place-items: center; cursor: pointer;
        transition: all 0.3s;
    }
    .btn-quick-view-v2:hover { background: rgba(0,0,0,0.15); border-color: rgba(0,0,0,0.3); transform: translateY(-2px); }
</style>

